# ── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Azure OpenAI (use instead of OpenAI above) ──────────
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── Model config ────────────────────────────────────────
# Default model to use (leave blank to auto-pick from API)
# ORION_DEFAULT_MODEL=gpt-4.1

# Comma-separated list to pin available models in the UI
# ORION_MODELS=gpt-4.1,gpt-4o,gpt-4o-mini
